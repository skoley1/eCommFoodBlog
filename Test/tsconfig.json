{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["../FoodBlog/src/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx"
  ]
}
